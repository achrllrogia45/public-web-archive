<!DOCTYPE html>
<html lang="en">
  <!-- https://settei-geometry.mahdeensky.top -->
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Settei Geometry: 3D Proportions Calculator</title>
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.8/dist/katex.min.css">
    <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.8/dist/katex.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>

    <style>
        :root {
            --bg-color: #0f172a; --panel-bg: #1e293b; --primary: #ef4444;
            --primary-hover: #dc2626; --text-main: #f8fafc; --text-muted: #94a3b8; --accent: #10b981;
        }
        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        
        body { 
            background-color: var(--bg-color); color: var(--text-main); 
            display: flex; flex-direction: row; height: 100vh; overflow: hidden;
            padding-top: 8px; box-sizing: border-box;
        }

        /* Sidebar */
        .sidebar {
            width: 420px; flex-shrink: 0; background-color: var(--panel-bg); padding: 20px;
            display: flex; flex-direction: column; gap: 20px; border-right: 1px solid #334155;
            overflow-y: auto; z-index: 100; box-shadow: 5px 0 15px rgba(0,0,0,0.3);
        }
        h1 { font-size: 1.3rem; text-align: center; color: white; }
        h2 { font-size: 1.1rem; border-bottom: 1px solid #334155; padding-bottom: 5px; margin-bottom: 10px; }
        
        /* Mode Toggle */
        .mode-toggle { display: flex; background: #0f172a; border-radius: 6px; padding: 4px; border: 1px solid #334155; }
        .mode-toggle button { flex: 1; background: transparent; color: var(--text-muted); border: none; padding: 10px; border-radius: 4px; cursor: pointer; font-weight: bold; transition: 0.2s; font-size: 0.9rem;}
        .mode-toggle button.active { background: var(--primary); color: white; }
        .mode-toggle button#modeBWH.active { background: var(--accent); color: white; }

        .control-group { display: flex; flex-direction: column; gap: 8px; }
        .row { display: flex; gap: 10px; align-items: center; }
        .grid-filters { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; font-size: 0.85rem; }
        label { font-size: 0.85rem; font-weight: 600; color: var(--text-muted); text-transform: uppercase; }
        .filter-label { text-transform: none; color: var(--text-main); cursor: pointer; display: flex; align-items: center; gap: 5px;}
        
        input[type="number"], select {
            background: #0f172a; border: 1px solid #334155; color: white;
            padding: 8px 12px; border-radius: 6px; outline: none; width: 100%;
        }
        input[type="range"] { flex-grow: 1; cursor: pointer; }
        
        .btn {
            background-color: var(--primary); color: white; border: none; padding: 12px;
            border-radius: 6px; font-weight: bold; cursor: pointer; transition: 0.2s;
            text-transform: uppercase; letter-spacing: 1px; width: 100%;
        }
        .btn:hover { background-color: var(--primary-hover); }
        .btn:disabled { background-color: #475569; cursor: not-allowed; }
        .btn-secondary { background-color: #3b82f6; }
        .btn-secondary:hover { background-color: #2563eb; }
        .btn-outline { background-color: transparent; border: 1px solid var(--text-muted); padding: 6px 12px; font-size: 0.8rem; }
        .btn-outline:hover { background-color: rgba(255,255,255,0.1); }

        .file-upload {
            background: #0f172a; border: 2px dashed #475569; padding: 25px;
            text-align: center; border-radius: 6px; cursor: pointer; transition: 0.2s;
        }
        .file-upload.drag-over { border-color: var(--primary); background: rgba(239, 68, 68, 0.1); }
        .file-upload input { display: none; }

        /* Guide Accordion */
        details.guide { background: #0f172a; border-radius: 6px; border: 1px solid #334155; padding: 10px 15px; }
        details.guide summary { cursor: pointer; font-weight: 600; font-size: 0.95rem; color: var(--primary); display: flex; justify-content: space-between; align-items: center; }
        details.guide.bwh-guide summary { color: var(--accent); }
        details.guide summary::-webkit-details-marker { display: none; }
        details.guide summary:after { content: '▼'; font-size: 0.8em; transition: transform 0.2s; }
        details.guide[open] summary:after { transform: rotate(180deg); }
        .guide-content { margin-top: 10px; padding-top: 10px; border-top: 1px dashed #334155; font-size: 0.85rem; color: var(--text-muted); display: flex; flex-direction: column; gap: 10px; }
        .guide-content p { line-height: 1.4; color: var(--text-muted); font-size: 0.85rem;}

        /* Footer Credits */
        .footer {
            margin-top: auto; padding-top: 15px; border-top: 1px solid #334155;
            display: flex; flex-direction: column; gap: 12px; font-size: 0.85rem; color: var(--text-muted);
        }
        .footer span { font-weight: 600; color: var(--text-main); }

        /* Main Area */
        .main-area { flex-grow: 1; display: flex; flex-direction: column; overflow-y: auto; position: relative; scroll-behavior: smooth; }
        .workspace { 
            min-height: 100vh; position: relative; overflow: hidden; cursor: grab; 
            background: repeating-linear-gradient(45deg, #0f172a, #0f172a 10px, #131c31 10px, #131c31 20px); 
            touch-action: none; 
        }
        .workspace:active { cursor: grabbing; }

        /* Floating Contextual Guide */
        .floating-guide { 
            position: absolute; bottom: 30px; right: 30px; background: rgba(15, 23, 42, 0.95); 
            border-left: 4px solid var(--primary); border-radius: 6px; padding: 15px; width: 450px; 
            box-shadow: 0 10px 25px rgba(0,0,0,0.5); backdrop-filter: blur(5px); z-index: 50; 
            pointer-events: none; opacity: 1; transition: opacity 0.3s; line-height: 1.5; font-size: 0.9rem; 
        }

        /* Image & Lines */
        .viewport-wrapper { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); transform-origin: center center; display: none; }
        .img-container { position: relative; box-shadow: 0 0 20px rgba(0,0,0,0.5); background: #fff; display: inline-block; --line-w: 2px;}
        .img-container img { display: block; max-width: 90vw; max-height: 85vh; width: auto; height: auto; user-select: none; pointer-events: none; }
        
        .measure-line { position: absolute; background-color: var(--primary); box-shadow: 0 0 8px var(--primary); z-index: 20; }
        .measure-line.h-line { width: 100%; height: var(--line-w); cursor: ns-resize; left: 0; }
        .measure-line.v-line { height: 100%; width: var(--line-w); cursor: ew-resize; top: 0; }
        .measure-line::after { content: ''; position: absolute; z-index: 21; }
        .measure-line.h-line::after { top: -15px; bottom: -15px; left: 0; right: 0; }
        .measure-line.v-line::after { left: -15px; right: -15px; top: 0; bottom: 0; }
        
        /* Draggable Labels */
        .line-label { 
            position: absolute; background: rgba(0,0,0,0.8); color: white; font-size: 0.75rem; 
            padding: 4px 8px; border-radius: 4px; white-space: nowrap; border: 1px solid #475569;
            pointer-events: auto; cursor: grab; z-index: 22; box-shadow: 0 2px 5px rgba(0,0,0,0.5);
        }
        .line-label:active { cursor: grabbing; background: rgba(239, 68, 68, 0.9); }
        .hide-labels .line-label { display: none !important; }

        /* Dynamic Span Tethers & Labels */
        .span-line {
            position: absolute; z-index: 15; display: flex; align-items: center; justify-content: center;
            opacity: 0.85; cursor: grab; pointer-events: auto;
        }
        .span-line:active { cursor: grabbing; opacity: 1; }
        .span-line.v-span { width: var(--line-w); border-left: var(--line-w) dashed currentColor; }
        .span-line.h-span { height: var(--line-w); border-top: var(--line-w) dashed currentColor; }
        .span-line::after { content: ''; position: absolute; z-index: 16; }
        .span-line.v-span::after { left: -15px; right: -15px; top: 0; bottom: 0; }
        .span-line.h-span::after { top: -15px; bottom: -15px; left: 0; right: 0; }
        
        .span-label {
            background: rgba(0,0,0,0.8); color: white; font-size: 0.65rem; font-weight: bold;
            padding: 3px 6px; border-radius: 4px; position: absolute; pointer-events: auto; cursor: grab;
            z-index: 17; left: 50%; top: 50%; transform: translate(-50%, -50%); border: 1px solid #475569;
            box-shadow: 0 2px 5px rgba(0,0,0,0.5); white-space: nowrap;
        }
        .span-label:active { cursor: grabbing; background: rgba(239, 68, 68, 0.9); }
        .hide-span-labels .span-label { display: none !important; }

        /* Pixel Loupe Magnifier */
        #loupeCanvas {
            position: fixed; width: 140px; height: 140px; border-radius: 50%;
            border: 3px solid var(--primary); pointer-events: none; display: none; z-index: 9999;
            box-shadow: 0 0 20px rgba(0,0,0,0.9); image-rendering: pixelated; background: #0f172a;
        }

        /* Animation Math Board */
        .math-board { min-height: 60vh; background-color: #0b1120; padding: 50px; border-top: 2px solid var(--primary); display: none; flex-direction: column; gap: 30px; }
        .math-step { background: #1e293b; border-radius: 8px; padding: 25px; border-left: 4px solid var(--accent); opacity: 0; transform: translateY(20px); transition: all 0.5s ease-out; box-shadow: 0 5px 15px rgba(0,0,0,0.2); }
        .math-step.visible { opacity: 1; transform: translateY(0); }
        .step-title { font-size: 1.2rem; font-weight: bold; margin-bottom: 15px; color: var(--accent); }
        .final-result-card { text-align: center; padding: 40px; background: linear-gradient(145deg, #1e293b, #0f172a); border-radius: 12px; border: 1px solid var(--primary); margin-top: 20px; }
        .final-result-card h3 { font-size: 1.5rem; color: var(--text-muted); }
        .final-result-card .main-stat { font-size: 4.5rem; font-weight: bold; color: var(--primary); text-shadow: 0 0 20px rgba(239, 68, 68, 0.4); margin: 10px 0; }
        .final-result-card .sub-stat { font-size: 1.2rem; color: var(--text-muted); }

        /* Export Overlay */
        .draggable-math-overlay {
            position: absolute; top: 20px; right: 20px; background: rgba(15,23,42,0.9); color: white;
            padding: 1.2em; border-radius: 8px; border: 2px solid var(--primary); backdrop-filter: blur(5px);
            display: none; z-index: 1000; font-family: sans-serif; box-shadow: 0 0 20px rgba(0,0,0,0.8);
            cursor: grab; min-width: 50px; min-height: 50px; overflow: hidden; font-size: 16px;
        }
        .draggable-math-overlay:active { cursor: grabbing; }
        .export-title { font-size: 1.1em; font-weight: bold; color: var(--accent); margin-bottom: 0.5em; border-bottom: 1px solid #334155; padding-bottom: 0.3em; text-align: center;}
        .export-katex { font-size: 0.95em; margin-bottom: 1em; }
        .export-result { text-align: center; border-top: 1px solid #334155; padding-top: 0.8em; }
        .resize-handle {
            position: absolute; bottom: 0; right: 0; width: 35px; height: 35px;
            cursor: se-resize; z-index: 1001;
            background: linear-gradient(135deg, transparent 50%, var(--primary) 50%);
            border-bottom-right-radius: 6px;
        }

        /* Fixed Export Controls */
        .export-controls {
            position: fixed; bottom: 30px; left: 50%; transform: translateX(-50%);
            display: none; gap: 15px; z-index: 2000; background: rgba(15, 23, 42, 0.95);
            padding: 15px 25px; border-radius: 50px; box-shadow: 0 10px 30px rgba(0,0,0,0.8);
            border: 1px solid #334155;
        }
        .export-controls button {
            padding: 12px 24px; font-size: 1rem; border-radius: 50px; font-weight: bold; 
            border: none; cursor: pointer; text-transform: uppercase; letter-spacing: 0.5px;
        }
        #saveConfirmBtn { background: var(--accent); color: #fff; }
        #saveConfirmBtn:hover { background: #059669; }
        #cancelExportBtn { background: #ef4444; color: #fff; }
        #cancelExportBtn:hover { background: #dc2626; }
    </style>
</head>
<body>
<header style="display: block; position: fixed; top: 0; left: 0; right: 0; height: 28px; background: rgba(15, 23, 42, 0.95); color: #94a3b8; font-size: 0.7rem; text-align: center; line-height: 28px; z-index: 200; border-bottom: 1px solid #334155; backdrop-filter: blur(5px);">
  <a href="https://settei-geometry.mahdeensky.top" target="_blank" style="color: #94a3b8; text-decoration: none;"> https://settei-geometry.mahdeensky.top </a>
</header>

    <canvas id="loupeCanvas" width="140" height="140" data-html2canvas-ignore="true"></canvas>

    <div class="sidebar">
        <h1>Settei Geometry</h1>

        <div class="mode-toggle">
            <button id="modeCup" class="active">Cup Size</button>
            <button id="modeBWH">Three Sizes (BWH)</button>
        </div>
        
        <label class="file-upload" id="uploadBtn">
            <span id="uploadText">Click or Drop Ref Sheet Here</span>
            <input type="file" id="imageLoader" accept="image/*">
        </label>

        <div class="control-group">
            <h2>1. Canonical Height</h2>
            <div class="row">
                <input type="number" id="heightCm" value="160" placeholder="cm">
                <div id="heightFtIn" style="display:none; gap:10px; width:100%;">
                    <input type="number" id="heightFt" value="5" placeholder="ft" style="width:50%;">
                    <input type="number" id="heightIn" value="3" placeholder="in" style="width:50%;">
                </div>
                <select id="heightUnit" style="width: 90px;">
                    <option value="cm">cm</option>
                    <option value="ftin">ft / in</option>
                </select>
            </div>
        </div>

        <details class="guide" id="guideCup">
            <summary>How It's Calculated</summary>
            <div class="guide-content">
                <p><b>1. Ramanujan's Approximation:</b> Because the torso is an ellipse, we use the semi-major axis (<i>a</i>) and semi-minor axis (<i>b</i>) to calculate circumference (<i>C</i>).</p>
                <div id="ramanujanExplained"></div>
                <p><b>2. Delta & Cup Size:</b> We run this for Bust and Underbust. The difference (Δ) dictates cup volume.</p>
            </div>
        </details>

        <details class="guide bwh-guide" id="guideBWH" style="display:none;">
            <summary>How "Three Sizes" Work</summary>
            <div class="guide-content">
                <p>We use the same ellipse geometry but apply it to three zones to generate the classic B-W-H anime stats.</p>
                <p><b>Waist:</b> Measure the absolute narrowest point of the abdomen.</p>
                <p><b>Hips:</b> Measure the absolute widest point of the pelvis and furthest protrusion of the glutes.</p>
            </div>
        </details>

        <div class="control-group">
            <div class="row" style="justify-content: space-between;">
                <h2>2. Measurement Settings</h2>
                <button class="btn btn-outline" id="resetViewBtn">Reset View</button>
            </div>
            
            <div class="row">
                <label style="width: 110px;">Line Thickness</label>
                <input type="range" id="lineWidth" min="1" max="6" value="2" autocomplete="off">
                <span id="lineWidthVal" style="font-size:0.8em; width:30px; text-align:right;">2px</span>
            </div>

            <div class="row" id="cupSystemRow">
                <label style="width: 110px;">Sizing System</label>
                <select id="cupSystem">
                    <option value="jis">JIS (Japan)</option>
                    <option value="us">US / UK Strict</option>
                </select>
            </div>
            
            <label style="display:flex; gap:5px; align-items:center; margin-top:10px;">
                <input type="checkbox" id="showSpanLines" checked> <span style="text-transform:none; color:white;">Show Measurement Tethers</span>
            </label>
            
            <div class="row" style="gap:15px; margin-top: 5px;">
                <label style="display:flex; gap:5px; align-items:center;">
                    <input type="checkbox" id="hideLabelsToggle"> <span style="text-transform:none; color:white;">Hide Red Labels</span>
                </label>
                <label style="display:flex; gap:5px; align-items:center;">
                    <input type="checkbox" id="hideSpanLabelsToggle"> <span style="text-transform:none; color:white;">Hide Span Labels</span>
                </label>
            </div>

            <!-- Cup Filters -->
            <div id="filtersCup" class="grid-filters" style="margin-top: 10px;">
                <label class="filter-label"><input type="radio" name="viewModeCup" value="all" checked> Show All</label>
                <label class="filter-label"><input type="radio" name="viewModeCup" value="h"> Height Only</label>
                <label class="filter-label"><input type="radio" name="viewModeCup" value="uw"> Underbust W</label>
                <label class="filter-label"><input type="radio" name="viewModeCup" value="ud"> Underbust D</label>
                <label class="filter-label"><input type="radio" name="viewModeCup" value="bw"> Bust W</label>
                <label class="filter-label"><input type="radio" name="viewModeCup" value="bd"> Bust D</label>
            </div>

            <!-- BWH Filters -->
            <div id="filtersBWH" class="grid-filters" style="margin-top: 10px; display:none;">
                <label class="filter-label"><input type="radio" name="viewModeBWH" value="all" checked> Show All</label>
                <label class="filter-label"><input type="radio" name="viewModeBWH" value="h"> Height Only</label>
                <label class="filter-label"><input type="radio" name="viewModeBWH" value="bw"> Bust W</label>
                <label class="filter-label"><input type="radio" name="viewModeBWH" value="bd"> Bust D</label>
                <label class="filter-label"><input type="radio" name="viewModeBWH" value="ww"> Waist W</label>
                <label class="filter-label"><input type="radio" name="viewModeBWH" value="wd"> Waist D</label>
                <label class="filter-label"><input type="radio" name="viewModeBWH" value="hw"> Hip W</label>
                <label class="filter-label"><input type="radio" name="viewModeBWH" value="hd"> Hip D</label>
            </div>
        </div>

        <div class="control-group" style="gap: 15px; margin-top: auto;">
            <div class="row">
                <input type="checkbox" id="showAnimation" checked style="width:auto;">
                <label for="showAnimation" style="text-transform:none;">Enable Math Animation</label>
            </div>
            <button class="btn" id="calcBtn" disabled>Calculate Proportions</button>
            <button class="btn btn-secondary" id="exportBtn" disabled>Export Image</button>
        </div>

        <footer class="footer">
            <span>By TheDarkEnjoyer</span>
        </footer>
    </div>

    <div class="main-area" id="mainArea">
        <div class="workspace" id="workspace">
            <div class="viewport-wrapper" id="viewportWrapper">
                <div class="img-container" id="imgContainer">
                    <img id="refImage" src="" alt="Reference Sheet">
                    
                    <div id="draggableMath" class="draggable-math-overlay">
                        <div class="export-title" id="exportTitleText">Settei Geometry</div>
                        <div id="exportMathContent" class="export-katex"></div>
                        <div class="export-result" id="exportResultContainer"></div>
                        <div class="resize-handle" id="mathResizeHandle"></div>
                    </div>
                </div>
            </div>
            
            <div id="contextualGuide" class="floating-guide">
                <b>Show All Lines:</b> Displays all measurement lines on the canvas to give you a full overview of the geometry. Use this to double-check that your front and side measurements perfectly align horizontally.
            </div>
            
            <div class="export-controls" id="exportControls">
                <button id="saveConfirmBtn">Confirm & Save</button>
                <button id="cancelExportBtn">Cancel</button>
            </div>
        </div>

        <div class="math-board" id="mathBoard"></div>
    </div>

    <script>
        // --- DOM Elements ---
        const imageLoader = document.getElementById('imageLoader');
        const uploadBtn = document.getElementById('uploadBtn');
        const refImage = document.getElementById('refImage');
        const imgContainer = document.getElementById('imgContainer');
        const viewportWrapper = document.getElementById('viewportWrapper');
        const workspace = document.getElementById('workspace');
        const mathBoard = document.getElementById('mathBoard');
        const contextualGuide = document.getElementById('contextualGuide');
        const calcBtn = document.getElementById('calcBtn');
        const exportBtn = document.getElementById('exportBtn');
        const showSpanLinesTgl = document.getElementById('showSpanLines');
        
        // Settings Elements
        const lineWidthInput = document.getElementById('lineWidth');
        const lineWidthVal = document.getElementById('lineWidthVal');
        const heightUnit = document.getElementById('heightUnit');
        const heightCm = document.getElementById('heightCm');
        const heightFtIn = document.getElementById('heightFtIn');
        const heightFt = document.getElementById('heightFt');
        const heightIn = document.getElementById('heightIn');

        // Export Elements
        const draggableMath = document.getElementById('draggableMath');
        const resizeHandle = document.getElementById('mathResizeHandle');
        const exportControls = document.getElementById('exportControls');
        const saveConfirmBtn = document.getElementById('saveConfirmBtn');
        const cancelExportBtn = document.getElementById('cancelExportBtn');
        const exportResultContainer = document.getElementById('exportResultContainer');

        // Loupe Engine
        const loupeCanvas = document.getElementById('loupeCanvas');
        const loupeCtx = loupeCanvas.getContext('2d');
        loupeCtx.imageSmoothingEnabled = false;

        // State & Mode
        let currentMode = 'cup'; // 'cup' or 'bwh'
        let scale = 1; let panX = 0; let panY = 0;
        let isPanning = false; let startPanX = 0; let startPanY = 0;
        let lineElements = {}; let spanElements = {};
        let draggingLine = null; let draggingSpan = null;
        let lastMathData = null;

        // Label Dragger State
        let draggingLabel = null;
        let labelStartX, labelStartY, labelStartTx, labelStartTy;
        let initialPinchDistance = null; let initialScale = 1;

        // --- Master Line Definitions ---
        const masterLineDefs = [
            { id: 'h1', type: 'h', label: 'Top of Head', val: 5, modes: ['cup', 'bwh'] },
            { id: 'h2', type: 'h', label: 'Bottom of Feet', val: 95, modes: ['cup', 'bwh'] },
            
            { id: 'uw1', type: 'v', label: 'UB-Width L', val: 20, modes: ['cup'] },
            { id: 'uw2', type: 'v', label: 'UB-Width R', val: 30, modes: ['cup'] },
            { id: 'ud1', type: 'v', label: 'UB-Depth Front', val: 65, modes: ['cup'] },
            { id: 'ud2', type: 'v', label: 'UB-Depth Back', val: 72, modes: ['cup'] },
            
            { id: 'bw1', type: 'v', label: 'Bust-Width L', val: 18, modes: ['cup', 'bwh'] },
            { id: 'bw2', type: 'v', label: 'Bust-Width R', val: 32, modes: ['cup', 'bwh'] },
            { id: 'bd1', type: 'v', label: 'Bust-Depth Front', val: 63, modes: ['cup', 'bwh'] },
            { id: 'bd2', type: 'v', label: 'Bust-Depth Back', val: 73, modes: ['cup', 'bwh'] },

            { id: 'ww1', type: 'v', label: 'Waist-Width L', val: 22, modes: ['bwh'] },
            { id: 'ww2', type: 'v', label: 'Waist-Width R', val: 28, modes: ['bwh'] },
            { id: 'wd1', type: 'v', label: 'Waist-Depth Front', val: 66, modes: ['bwh'] },
            { id: 'wd2', type: 'v', label: 'Waist-Depth Back', val: 71, modes: ['bwh'] },

            { id: 'hw1', type: 'v', label: 'Hip-Width L', val: 16, modes: ['bwh'] },
            { id: 'hw2', type: 'v', label: 'Hip-Width R', val: 34, modes: ['bwh'] },
            { id: 'hd1', type: 'v', label: 'Hip-Depth Front', val: 65, modes: ['bwh'] },
            { id: 'hd2', type: 'v', label: 'Hip-Depth Back', val: 76, modes: ['bwh'] }
        ];

        const masterSpanDefs = [
            { id: 'span_h', lines: ['h1', 'h2'], dir: 'v', color: '#10b981', label: 'Height', val: 10, align: 'center', modes: ['cup', 'bwh'] },
            
