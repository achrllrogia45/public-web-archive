                const finalCard = document.createElement('div'); finalCard.className = 'final-result-card';
                let diffPrint = system === 'jis' ? `${diff.toFixed(2)} cm` : `${(diff/2.54).toFixed(2)} inches`;
                finalCard.innerHTML = `<h3>Estimated ${sysStr} Size</h3><div class="main-stat">${cup} Cup</div><p class="sub-stat">Difference: ${diffPrint}</p>`;
                mathBoard.appendChild(finalCard);
            } 
            else {
                // BWH Mode Calculations
                const bw_cm = getPxDist('bw1', 'bw2', intrinsicW) * scaleFactor;
                const bd_cm = getPxDist('bd1', 'bd2', intrinsicW) * scaleFactor;
                const ww_cm = getPxDist('ww1', 'ww2', intrinsicW) * scaleFactor;
                const wd_cm = getPxDist('wd1', 'wd2', intrinsicW) * scaleFactor;
                const hw_cm = getPxDist('hw1', 'hw2', intrinsicW) * scaleFactor;
                const hd_cm = getPxDist('hd1', 'hd2', intrinsicW) * scaleFactor;

                const a_b = bw_cm / 2; const b_b = bd_cm / 2;
                const a_w = ww_cm / 2; const b_w = wd_cm / 2;
                const a_h = hw_cm / 2; const b_h = hd_cm / 2;

                const c_b = calcPerimeter(a_b, b_b);
                const c_w = calcPerimeter(a_w, b_w);
                const c_h = calcPerimeter(a_h, b_h);

                // Body Shape Logic
                let balanceText = "Balanced Proportions";
                if (c_b - c_h >= 2.5) balanceText = "Top-heavy Figure";
                else if (c_h - c_b >= 2.5) balanceText = "Bottom-heavy Figure";

                lastMathData = { mode: 'bwh', ab: a_b, bb: b_b, cb: c_b, aw: a_w, bw: b_w, cw: c_w, ah: a_h, bh: b_h, ch: c_h, balance: balanceText };

                createMathStep("Step 2: Bust Circumference", String.raw`C_b \approx \pi \left[ 3(${a_b.toFixed(1)}+${b_b.toFixed(1)}) - \sqrt{\dots} \right] \\ C_b = ${c_b.toFixed(2)} \mathrm{cm}`);
                await sleep(animDelay);
                createMathStep("Step 3: Waist Circumference", String.raw`C_w \approx \pi \left[ 3(${a_w.toFixed(1)}+${b_w.toFixed(1)}) - \sqrt{\dots} \right] \\ C_w = ${c_w.toFixed(2)} \mathrm{cm}`);
                await sleep(animDelay);
                createMathStep("Step 4: Hip Circumference", String.raw`C_h \approx \pi \left[ 3(${a_h.toFixed(1)}+${b_h.toFixed(1)}) - \sqrt{\dots} \right] \\ C_h = ${c_h.toFixed(2)} \mathrm{cm}`);
                await sleep(animDelay > 0 ? 1000 : 0);

                const finalCard = document.createElement('div'); finalCard.className = 'final-result-card';
                finalCard.style.borderColor = 'var(--accent)';
                finalCard.innerHTML = `
                    <h3>Official Three Sizes</h3>
                    <div class="main-stat" style="color:var(--accent);">B${Math.round(c_b)} - W${Math.round(c_w)} - H${Math.round(c_h)}</div>
                    <div class="sub-stat" style="font-size: 1.1rem; color: var(--text-muted); margin-top: 5px;">${balanceText}</div>
                `;
                mathBoard.appendChild(finalCard);
            }

            setTimeout(() => { mathBoard.lastChild.scrollIntoView({ behavior: 'smooth', block: 'center' }); }, 100);
            calcBtn.disabled = false; exportBtn.disabled = false;
        });

        // --- Draggable & Resizable Overlay Logic ---
        function startMathDrag(e) {
            const rect = draggableMath.getBoundingClientRect(); const pos = getPos(e);
            if((pos.x > rect.right - 35) && (pos.y > rect.bottom - 35)) return; // Pass to resize
            isDraggingMath = true; mathOffsetX = pos.x - rect.left; mathOffsetY = pos.y - rect.top;
            e.stopPropagation(); 
        }

        function startMathResize(e) {
            isResizingMath = true; const pos = getPos(e);
            initialMouseX = pos.x; initialMouseY = pos.y;
            const rect = draggableMath.getBoundingClientRect();
            initialMathWidth = rect.width / scale; initialMathHeight = rect.height / scale;
            e.stopPropagation(); e.preventDefault();
        }

        draggableMath.addEventListener('mousedown', startMathDrag);
        draggableMath.addEventListener('touchstart', startMathDrag, {passive: false});
        resizeHandle.addEventListener('mousedown', startMathResize);
        resizeHandle.addEventListener('touchstart', startMathResize, {passive: false});

        // --- Export Studio Sequence ---
        let savedTransform = { scale: 1, panX: 0, panY: 0 };

        exportBtn.addEventListener('click', () => {
            mainArea.scrollTo({ top: 0, behavior: 'smooth' });
            savedTransform = { scale, panX, panY }; resetView();
            document.querySelector('.sidebar').style.opacity = '0.3'; document.querySelector('.sidebar').style.pointerEvents = 'none';

            if (lastMathData.mode === 'cup') {
                document.getElementById('exportTitleText').innerText = "Settei Geometry Calculations";
                document.getElementById('exportTitleText').style.color = "var(--primary)";
                draggableMath.style.borderColor = "var(--primary)";
                resizeHandle.style.background = "linear-gradient(135deg, transparent 50%, var(--primary) 50%)";
                
                let deltaPrint = lastMathData.sysStr === 'JIS' ? `${lastMathData.diff.toFixed(2)}cm` : `${(lastMathData.diff/2.54).toFixed(2)}in`;
                exportResultContainer.innerHTML = `
                    <div style="font-size: 0.9em; color: #94a3b8;">Estimated Cup Size (${lastMathData.sysStr})</div>
                    <div style="font-size: 3.5em; color: #ef4444; font-weight: bold; text-shadow: 0 0 10px rgba(239,68,68,0.5);">${lastMathData.cup} Cup</div>
                    <div style="font-size: 0.8em; color: #94a3b8;">Δ: ${deltaPrint}</div>
                `;
                
                const fullMathHTML = String.raw`
                    C \approx \pi \left[ 3(a+b) - \sqrt{(3a+b)(a+3b)} \right] \\
                    \begin{aligned}
                    a_u &= ${lastMathData.au.toFixed(1)}, & b_u &= ${lastMathData.bu.toFixed(1)} &\Rightarrow C_u &= ${lastMathData.cu.toFixed(1)}\mathrm{cm} \\
                    a_b &= ${lastMathData.ab.toFixed(1)}, & b_b &= ${lastMathData.bb.toFixed(1)} &\Rightarrow C_b &= ${lastMathData.cb.toFixed(1)}\mathrm{cm}
                    \end{aligned} \\
                    \Delta = C_b - C_u = ${lastMathData.diff.toFixed(1)}\mathrm{cm}
                `;
                katex.render(fullMathHTML, document.getElementById('exportMathContent'), {displayMode: true});
                
            } else {
                document.getElementById('exportTitleText').innerText = "Official Three Sizes (BWH)";
                document.getElementById('exportTitleText').style.color = "var(--accent)";
                draggableMath.style.borderColor = "var(--accent)";
                resizeHandle.style.background = "linear-gradient(135deg, transparent 50%, var(--accent) 50%)";

                exportResultContainer.innerHTML = `
                    <div style="font-size: 0.9em; color: #94a3b8;">Calculated Proportions</div>
                    <div style="font-size: 3.2em; color: #10b981; font-weight: bold; text-shadow: 0 0 10px rgba(16,185,129,0.5); margin:10px 0;">B${Math.round(lastMathData.cb)} - W${Math.round(lastMathData.cw)} - H${Math.round(lastMathData.ch)}</div>
                    <div style="font-size: 1em; color: #94a3b8; margin-top: 5px;">${lastMathData.balance}</div>
                `;

                const fullMathHTML = String.raw`
                    \begin{aligned}
                    \mathrm{Bust}& \Rightarrow a= ${lastMathData.ab.toFixed(1)}, b= ${lastMathData.bb.toFixed(1)} &\rightarrow C_b &\approx ${Math.round(lastMathData.cb)}\mathrm{cm} \\
                    \mathrm{Waist}& \Rightarrow a= ${lastMathData.aw.toFixed(1)}, b= ${lastMathData.bw.toFixed(1)} &\rightarrow C_w &\approx ${Math.round(lastMathData.cw)}\mathrm{cm} \\
                    \mathrm{Hips}& \Rightarrow a= ${lastMathData.ah.toFixed(1)}, b= ${lastMathData.bh.toFixed(1)} &\rightarrow C_h &\approx ${Math.round(lastMathData.ch)}\mathrm{cm}
                    \end{aligned}
                `;
                katex.render(fullMathHTML, document.getElementById('exportMathContent'), {displayMode: true});
            }

            draggableMath.style.display = 'block';
            exportControls.style.display = 'flex';
            
            const rect = draggableMath.getBoundingClientRect();
            draggableMath.style.fontSize = Math.max(4, (rect.width / 450) * 16) + 'px';
        });

        cancelExportBtn.addEventListener('click', () => {
            draggableMath.style.display = 'none'; exportControls.style.display = 'none';
            document.querySelector('.sidebar').style.opacity = '1'; document.querySelector('.sidebar').style.pointerEvents = 'auto';
            scale = savedTransform.scale; panX = savedTransform.panX; panY = savedTransform.panY; updateTransform();
        });

        saveConfirmBtn.addEventListener('click', async () => {
            saveConfirmBtn.innerText = "Processing..."; saveConfirmBtn.disabled = true;

            const stagingArea = document.createElement('div');
            stagingArea.style.position = 'fixed'; stagingArea.style.top = '0'; stagingArea.style.left = '-9999px';
            stagingArea.style.width = refImage.naturalWidth + 'px'; stagingArea.style.height = refImage.naturalHeight + 'px';
            stagingArea.style.zIndex = '-1'; document.body.appendChild(stagingArea);

            const clone = imgContainer.cloneNode(true);
            const widthRatio = refImage.naturalWidth / imgContainer.offsetWidth;
            const heightRatio = refImage.naturalHeight / imgContainer.offsetHeight;

            clone.style.transform = 'none'; clone.style.left = '0'; clone.style.top = '0';
            clone.style.width = '100%'; clone.style.height = '100%';
            clone.style.setProperty('--line-w', lineWidthInput.value + 'px');

            const cloneImg = clone.querySelector('img');
            if (cloneImg) {
                cloneImg.style.maxWidth = 'none'; cloneImg.style.maxHeight = 'none';
                cloneImg.style.width = '100%'; cloneImg.style.height = '100%';
            }

            const overlayOnClone = clone.querySelector('#draggableMath');
            if (overlayOnClone) {
                overlayOnClone.style.backdropFilter = 'none'; overlayOnClone.style.webkitBackdropFilter = 'none';
                overlayOnClone.style.background = 'rgba(15, 23, 42, 1)'; overlayOnClone.style.boxShadow = 'none'; 
                
                const handleOnClone = overlayOnClone.querySelector('.resize-handle');
                if (handleOnClone) handleOnClone.style.display = 'none';
                
                const currentLeft = parseFloat(getComputedStyle(draggableMath).left) || 20;
                const currentTop = parseFloat(getComputedStyle(draggableMath).top) || 20;
                const currentWidth = parseFloat(getComputedStyle(draggableMath).width);
                const currentHeight = parseFloat(getComputedStyle(draggableMath).height);
                const currentFontSize = parseFloat(getComputedStyle(draggableMath).fontSize);
                
                overlayOnClone.style.left = (currentLeft * widthRatio) + 'px';
                overlayOnClone.style.top = (currentTop * heightRatio) + 'px';
                overlayOnClone.style.width = (currentWidth * widthRatio) + 'px';
                overlayOnClone.style.height = (currentHeight * heightRatio) + 'px';
                overlayOnClone.style.fontSize = (currentFontSize * widthRatio) + 'px';
            }

            stagingArea.appendChild(clone);

            try {
                const canvas = await html2canvas(clone, { 
                    backgroundColor: null, scale: 2, useCORS: true, logging: false,
                    width: refImage.naturalWidth, height: refImage.naturalHeight,
                    windowWidth: refImage.naturalWidth, windowHeight: refImage.naturalHeight,
                    ignoreElements: (element) => element.id === 'viewportWrapper' || element.id === 'loupeCanvas'
                });
                
                const link = document.createElement('a'); 
                link.download = currentMode === 'cup' ? 'Settei_CupSize.png' : 'Settei_ThreeSizes.png';
                link.href = canvas.toDataURL('image/png'); link.click();
            } catch (err) {
                console.error("Export failed:", err); alert("Failed to export image.");
            } finally {
                document.body.removeChild(stagingArea);
                saveConfirmBtn.innerText = "Confirm & Save"; saveConfirmBtn.disabled = false;
                cancelExportBtn.click();
            }
        });
    </script>
</body>
</html>
